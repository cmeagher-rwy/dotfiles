root = true

[*]
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[.gitconfig]
indent_style = tab
indent_size = 4

[*.{json,jsonc}]
indent_style = tab
indent_size = 2

[*.{ps1,psm1}]
indent_style = space
indent_size = 2

[*.{sh}]
indent_style = space
indent_size = 2

[*.{toml,yaml,yml}]
indent_style = space
indent_size = 2

[.wslconfig]
indent_style = space
indent_size = 2
