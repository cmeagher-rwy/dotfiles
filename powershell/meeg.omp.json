{
	"$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
	"blocks": [
		{
			"alignment": "left",
			"segments": [
				{
					"foreground": "#8BE9FD",
					"options": {
						"style": "agnoster_short",
						"max_depth": 3
					},
					"style": "plain",
					"template": "\uf07b {{ .Path }} ",
					"type": "path"
				},
				{
					"foreground": "#FF79C6",
					"options": {
						"fetch_status": true,
						"fetch_upstream_icon": true
					},
					"template": "<#BBBBBB>{{ .UpstreamIcon }} on</> {{ .HEAD }}{{if .BranchStatus }} {{ .BranchStatus }}{{ end }}{{ if .Working.Changed }} \uF044 {{ .Working.String }}{{ end }}{{ if and (.Staging.Changed) (.Working.Changed) }} |{{ end }}{{ if .Staging.Changed }} \uF046 {{ .Staging.String }}{{ end }} ",
					"type": "git",
					"style": "plain"
				},
				{
					"foreground": "#F1FA8C",
					"options": {
						"fetch_package_manager": true
					},
					"template": "<#BBBBBB>via</> \ue781 {{ if .PackageManagerIcon }}{{ .PackageManagerIcon }} {{ end }}{{ .Full }} ",
					"type": "node",
					"style": "plain"
				},
				{
					"foreground": "#BD93F9",
					"options": {
						"fetch_sdk_version": true
					},
					"template": "<#BBBBBB>via</> \ue77f {{ if .Unsupported }}\uf071{{ else }}{{ .Full }}{{ end }} ",
					"type": "dotnet",
					"style": "plain"
				}
			],
			"type": "prompt"
		},
		{
			"alignment": "left",
			"newline": true,
			"segments": [
				{
					"options": {
						"time_format": "15:04"
					},
					"template": "{{ .CurrentDate | date .Format }} ",
					"foreground": "#BBBBBB",
					"type": "time",
					"style": "plain"
				},
				{
					"foreground": "#FF5555",
					"style": "plain",
					"template": "\udb80\ude38 ",
					"type": "root"
				},
				{
					"foreground": "#50FA7B",
					"style": "plain",
					"template": "\udb81\ude27 ",
					"type": "text"
				}
			],
			"type": "prompt"
		},
		{
			"alignment": "left",
			"segments": [
				{
					"foreground": "#FF5555",
					"options": {
						"always_enabled": false,
						"status_template": "{{ if eq .Code 0 }}\uf00c{{ else }}\uf071{{ end }}"
					},
					"template": "{{ .String }} ",
					"type": "status",
					"style": "plain"
				},
				{
					"options": {
						"always_enabled": true
					},
					"template": "<#BBBBBB>\udb81\udd1b</> {{ .FormattedMs }} ",
					"foreground": "#BBBBBB",
					"type": "executiontime",
					"style": "plain"
				}
			],
			"type": "rprompt"
		}
	],
	"version": 3
}
