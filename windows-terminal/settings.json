				"hidden": false,
				"name": "Debian",
				"source": "Windows.Terminal.Wsl",
				"startingDirectory": "~/projects"
			},
			{
				"commandline": "%SystemRoot%\\System32\\WindowsPowerShell\\v1.0\\powershell.exe",
